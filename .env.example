# My Nails Jūrmala — Environment Variables
# Copy to .env and fill in before deploying. Never commit .env.

# ── BOOKLA ────────────────────────────────────────────────────
# Obtain from your Bookla dashboard at https://bookla.lv
VITE_BOOKLA_COMPANY_ID=
VITE_BOOKLA_SERVICE_ID=

# ── API ───────────────────────────────────────────────────────
# Allowed CORS origin for the /api/booking route
ALLOWED_ORIGIN=https://mynailsjurmala.lv

# ── EMAIL DELIVERY ─────────────────────────────────────────────
# Used by api/booking.js to forward booking notifications
# Sign up at https://resend.com — free tier covers small salons
RESEND_API_KEY=
SALON_EMAIL=your@email.com
